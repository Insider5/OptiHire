# =============================================================
#  OptiHire — Environment Variables Template
#  Copy to .env and fill in your values:
#    Windows: copy .env.example .env
#    Linux/macOS: cp .env.example .env
# =============================================================

# ── Flask core ─────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to "production" on live server, "development" locally
FLASK_ENV=development

# ── AI / Gemini ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to use the built-in fallback question generator
GEMINI_API_KEY=

# ── Email (optional — leave blank to disable email sending) ─
# Uses Gmail SMTP by default; change MAIL_SERVER for other providers.
# Gmail: use an App Password, NOT your regular login password.
#   Create one at: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=OptiHire <noreply@optihire.ai>

# ── JWT (reserved for REST API layer — Phase 4) ────────────
JWT_SECRET_KEY=change-me-jwt-secret
